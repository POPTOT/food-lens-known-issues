{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Food Lens Known Issues Database",
  "type": "object",
  "required": ["version", "updated", "schema_version", "issues"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "issues": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue" }
    }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "required": [
        "id",
        "status",
        "match",
        "type",
        "severity",
        "title",
        "short",
        "evidence",
        "sources"
      ],
      "properties": {
        "id": { "type": "string" },
        "status": { "enum": ["active", "draft", "archived"] },
        "scope": { "enum": ["exact_product", "product_line", "brand_line", "category", "ingredient"] },
        "match": {
          "type": "object",
          "properties": {
            "barcodes": { "type": "array", "items": { "type": "string" } },
            "brand_names": { "type": "array", "items": { "type": "string" } },
            "product_keywords": { "type": "array", "items": { "type": "string" } },
            "category_tags": { "type": "array", "items": { "type": "string" } },
            "countries": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "type": {
          "enum": [
            "lawsuit",
            "lab_finding",
            "recall",
            "regulatory_notice",
            "regulatory_limit",
            "scientific_report",
            "brand_pattern"
          ]
        },
        "severity": { "enum": ["low", "medium", "high", "critical"] },
        "confidence": { "enum": ["low", "medium", "high"] },
        "title": { "type": "string" },
        "short": { "type": "string" },
        "details": { "type": "string" },
        "substances": { "type": "array", "items": { "type": "string" } },
        "finding": {
          "type": "object",
          "properties": {
            "value": { "type": ["number", "string"] },
            "unit": { "type": "string" },
            "comparison": { "type": "string" },
            "limit": { "type": ["number", "string"] },
            "limit_unit": { "type": "string" }
          },
          "additionalProperties": false
        },
        "evidence": {
          "type": "object",
          "required": ["year", "summary"],
          "properties": {
            "year": { "type": "integer" },
            "summary": { "type": "string" },
            "jurisdiction": { "type": "string" },
            "case_number": { "type": "string" },
            "testing_lab": { "type": "string" }
          },
          "additionalProperties": false
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "url", "type"],
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "type": { "enum": ["court", "regulator", "lab_report", "study", "news", "company_notice"] },
              "accessed": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
            },
            "additionalProperties": false
          }
        },
        "score_penalty": { "type": "integer", "minimum": 0, "maximum": 90 },
        "score_cap": { "type": "integer", "minimum": 0, "maximum": 100 },
        "display": {
          "type": "object",
          "properties": {
            "badge": { "type": "string" },
            "tone": { "enum": ["red", "amber", "black"] }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
